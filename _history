ado\n    if estado_sistema == \"HUMIDIFICANDO\":\n        pins.digital_write_pin(PIN_LED_AZUL, 1)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 1)\n        # Ventilador ON\n        pins.servo_write_pin(PIN_SERVO, 0)\n        # Compuerta Cerrada\n        music.play_tone(262, music.beat(BeatFraction.SIXTEENTH))\n    elif estado_sistema == \"SECANDO\":\n        # Beep suave\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 1)\n        pins.digital_write_pin(PIN_MOTOR, 1)\n        # Ventilador ON (Circulación)\n        pins.servo_write_pin(PIN_SERVO, 90)\n        # Compuerta ABIERTA\n        music.play_tone(523, music.beat(BeatFraction.EIGHTH))\n    else:\n        # Beep alerta\n        # ESTABLE\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 0)\n        # Todo apagado\n        pins.servo_write_pin(PIN_SERVO, 0)\nbasic.forever(on_forever)\n"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":135,"diffs":[[1,"/**\n * Apaga secado solo si baja a 60%\n */\nserial.onDataReceived(serial.delimiters(Delimiters.NewLine), function () {\n\t\n"]]},{"start1":123,"length1":310,"diffs":[[1,"// Aquí iría el bloque específico de la extensión DHT11\n// Simulamos lectura para este ejemplo de código base\n// En MakeCode real: humedad_actual = dht11.dht11_read(PIN_DHT11, dht11.DHT11Type.HUMIDITY)\nfunction leer_sensor () {\n    dht11_dht22.queryData(\n    DHTtype.DHT11,\n    DigitalPin.P8,\n    true,\n    false,\n    true\n    )\n"]]},{"start1":626,"length1":140,"diffs":[[1,"        makerbit.showStringOnLcd1602(\"\" + (dht11_dht22.readData(dataType.humidity)), makerbit.position1602(LcdPosition1602.Pos12), 16)\n"]]},{"start1":767,"length1":5,"diffs":[[1,""]]},{"start1":868,"length1":1,"diffs":[[1,""]]},{"start1":915,"length1":106,"diffs":[[1,"// PROYECTO: GUARDIÁN DEL CLIMA\n// Lógica c