\"#`A81%w8?PTpB[PNPP~N\">PIN_SERVO</field></block></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"180\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value></block></next></block></next></block></next></block></statement><next><block type=\"device_pause\"><comment pinned=\"false\" h=\"80\" w=\"160\">Compuerta Cerrada</comment><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value></block></next></block></next></block></next></block></statement></block><block type=\"function_definition\" x=\"1744\" y=\"0\"><mutation name=\"leer_sensor\" functionid=\"CEu|PynSFvn?3J5}7Wb*\"></mutation><field name=\"function_name\">leer_sensor</field><comment pinned=\"false\" h=\"80\" w=\"160\">Aquí iría el bloque específico de la extensión DHT11\nSimulamos lectura para este ejemplo de código base\nEn MakeCode real: humedad_actual = dht11.dht11_read(PIN_DHT11, dht11.DHT11Type.HUMIDITY)</comment></block><block type=\"function_definition\" x=\"2045\" y=\"0\"><mutation name=\"actualizar_barra_led\" functionid=\"#WByr)mp-1jHgvY5*~`=\"></mutation><field name=\"function_name\">actualizar_barra_led</field><statement name=\"STACK\"><block type=\"device_plot_bar_graph\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><comment pinned=\"false\" h=\"80\" w=\"160\">Mapea la humedad de 0-100 a un gráfico de 0-10 líneas en la pantalla\nO controla el módulo LED Bar externo aquí</comment><value name=\"value\"><block type=\"variables_get\"><field name=\"VAR\" id=\"nGyHu2iF!:iq8bZrdy6~\">humedad_actual</field></block></value><value name=\"high\"><shadow type=\"math_number\"><field name=\"NUM\">100</field></shadow></value></block></statement></block></xml>","main.ts":"","README.md":"","main.py":"# PROYECTO: GUARDIÁN DEL CLIMA\n# Lógica con Histéresis y Control de Estados\n\n# --- CONFIGURACIÓN ---\numbral_seco_activar = 45   # Enciende humidificador si baja de 45%\numbral_seco_apagar = 50    # Apaga humidificador solo si sube a 50% (Margen de seguridad)\n\numbral_humedo_activar = 65 # Enciende secado si sube de 65%\numbral_humedo_apagar = 60  # Apaga secado solo si baja a 60%\n\nhumedad_actual = 0\nestado_sistema = \"ESTABLE\" # Puede ser: ESTABLE, HUMIDIFICANDO, SECANDO\n\n# Pines (Ajustar según tabla de Hardware)\nPIN_DHT11 = DigitalPin.P1\nPIN_SERVO = AnalogPin.P2\nPIN_MOTOR = DigitalPin.P13\nPIN_LED_AZUL = DigitalPin.P14\nPIN_LED_ROJO = DigitalPin.P15\n\n# Inicialización\npins.servo_write_pin(PIN_SERVO, 0) # Cerrar compuerta\nbasic.show_icon(IconNames.TARGET)\n\ndef leer_sensor():\n    global humedad_actual\n    # Aquí iría el bloque específico de la extensión DHT11\n    # Simulamos lectura para este ejemplo de código base\n    # En MakeCode real: humedad_actual = dht11.dht11_read(PIN_DHT11, dht11.DHT11Type.HUMIDITY)\n    pass\n\ndef actualizar_barra_led():\n    # Mapea la humedad de 0-100 a un gráfico de 0-10 líneas en la pantalla\n    # O controla el módulo LED Bar externo aquí\n    led.plot_bar_graph(humedad_actual, 100)\n\ndef on_forever():\n    global humedad_actual, estado_sistema\n    \n    # 1. Lectura\n    # leer_sensor() (Descomentar al usar extensión real)\n    \n    # 2. Visualización\n    actualizar_barra_led()\n    \n    # 3. Lógica de Control con Histéresis\n    \n    # --- MODO HUMIDIFICACIÓN ---\n    if humedad_actual < umbral_seco_activar:\n        estado_sistema = \"HUMIDIFICANDO\"\n    elif estado_sistema == \"HUMIDIFICANDO\" and humedad_actual > umbral_seco_apagar:\n        estado_sistema = \"ESTABLE\"\n        \n    # --- MODO SECADO ---\n    elif humedad_actual > umbral_humedo_activar:\n        estado_sistema = \"SECANDO\"\n    elif estado_sistema == \"SECANDO\" and humedad_actual < umbral_humedo_apagar:\n        estado_sistema = \"ESTABLE\"\n        \n    # 4. Ejecución de Actuadores según Estado\n    \n    if estado_sistema == \"HUMIDIFICANDO\":\n        pins.digital_write_pin(PIN_LED_AZUL, 1)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 1)       # Ventilador ON\n        pins.servo_write_pin(PIN_SERVO, 0)         # Compuerta Cerrada\n        music.play_tone(262, music.beat(BeatFraction.SIXTEENTH)) # Beep suave\n        \n    elif estado_sistema == \"SECANDO\":\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 1)\n        pins.digital_write_pin(PIN_MOTOR, 1)       # Ventilador ON (Circulación)\n        pins.servo_write_pin(PIN_SERVO, 90)        # Compuerta ABIERTA\n        music.play_tone(523, music.beat(BeatFraction.EIGHTH)) # Beep alerta\n        \n    else: # ESTABLE\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 0)       # Todo apagado\n        pins.servo_write_pin(PIN_SERVO, 0)         # Compuerta Cerrada\n    \n    basic.pause(2000) # Leer cada 2 segundos\n\nbasic.forever(on_forever)","pxt.json":"{\n    \"name\": \"GUARIDAN DEL CLIMA 5TO\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.22\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/0657a603250be13848e043e55be26bb21bb0d9a7\",\n        \"target\": \"8.0.22\",\n        \"pxt\": \"12.0.19\"\n    },\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1781012981679,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"^9r0,!rZ,OFiQGTQ1Km+\">humedad_actual</variable><variable id=\"9YKYi6.CoTpc2UmiXpuB\">umbral_seco_activar</variable><variable id=\"gX]|of19x^!dEV/blHET\">estado_sistema</variable><var