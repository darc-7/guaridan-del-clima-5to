abled\"></block></value></block><block type=\"device_pause\" disabled-reasons=\"pxt_automatic_disabled\" x=\"649\" y=\"731\"><comment pinned=\"false\" h=\"80\" w=\"160\">Compuerta Cerrada</comment><value name=\"pause\"><shadow type=\"timePicker\" disabled-reasons=\"pxt_automatic_disabled\"><field name=\"ms\">2000</field></shadow></value></block></xml>","main.ts":"","README.md":"","main.py":"# PROYECTO: GUARDIÁN DEL CLIMA\n# Lógica con Histéresis y Control de Estados\n\n# --- CONFIGURACIÓN ---\numbral_seco_activar = 45   # Enciende humidificador si baja de 45%\numbral_seco_apagar = 50    # Apaga humidificador solo si sube a 50% (Margen de seguridad)\n\numbral_humedo_activar = 65 # Enciende secado si sube de 65%\numbral_humedo_apagar = 60  # Apaga secado solo si baja a 60%\n\nhumedad_actual = 0\nestado_sistema = \"ESTABLE\" # Puede ser: ESTABLE, HUMIDIFICANDO, SECANDO\n\n# Pines (Ajustar según tabla de Hardware)\nPIN_DHT11 = DigitalPin.P1\nPIN_SERVO = AnalogPin.P2\nPIN_MOTOR = DigitalPin.P13\nPIN_LED_AZUL = DigitalPin.P14\nPIN_LED_ROJO = DigitalPin.P15\n\n# Inicialización\npins.servo_write_pin(PIN_SERVO, 0) # Cerrar compuerta\nbasic.show_icon(IconNames.TARGET)\n\ndef leer_sensor():\n    global humedad_actual\n    # Aquí iría el bloque específico de la extensión DHT11\n    # Simulamos lectura para este ejemplo de código base\n    # En MakeCode real: humedad_actual = dht11.dht11_read(PIN_DHT11, dht11.DHT11Type.HUMIDITY)\n    pass\n\ndef actualizar_barra_led():\n    # Mapea la humedad de 0-100 a un gráfico de 0-10 líneas en la pantalla\n    # O controla el módulo LED Bar externo aquí\n    led.plot_bar_graph(humedad_actual, 100)\n\ndef on_forever():\n    global humedad_actual, estado_sistema\n    \n    # 1. Lectura\n    # leer_sensor() (Descomentar al usar extensión real)\n    \n    # 2. Visualización\n    actualizar_barra_led()\n    \n    # 3. Lógica de Control con Histéresis\n    \n    # --- MODO HUMIDIFICACIÓN ---\n    if humedad_actual < umbral_seco_activar:\n        estado_sistema = \"HUMIDIFICANDO\"\n    elif estado_sistema == \"HUMIDIFICANDO\" and humedad_actual > umbral_seco_apagar:\n        estado_sistema = \"ESTABLE\"\n        \n    # --- MODO SECADO ---\n    elif humedad_actual > umbral_humedo_activar:\n        estado_sistema = \"SECANDO\"\n    elif estado_sistema == \"SECANDO\" and humedad_actual < umbral_humedo_apagar:\n        estado_sistema = \"ESTABLE\"\n        \n    # 4. Ejecución de Actuadores según Estado\n    \n    if estado_sistema == \"HUMIDIFICANDO\":\n        pins.digital_write_pin(PIN_LED_AZUL, 1)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 1)       # Ventilador ON\n        pins.servo_write_pin(PIN_SERVO, 0)         # Compuerta Cerrada\n        music.play_tone(262, music.beat(BeatFraction.SIXTEENTH)) # Beep suave\n        \n    elif estado_sistema == \"SECANDO\":\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 1)\n        pins.digital_write_pin(PIN_MOTOR, 1)       # Ventilador ON (Circulación)\n        pins.servo_write_pin(PIN_SERVO, 90)        # Compuerta ABIERTA\n        music.play_tone(523, music.beat(BeatFraction.EIGHTH)) # Beep alerta\n        \n    else: # ESTABLE\n        pins.digital_write_pin(PIN_LED_AZUL, 0)\n        pins.digital_write_pin(PIN_LED_ROJO, 0)\n        pins.digital_write_pin(PIN_MOTOR, 0)       # Todo apagado\n        pins.servo_write_pin(PIN_SERVO, 0)         # Compuerta Cerrada\n    \n    basic.pause(2000) # Leer cada 2 segundos\n\nbasic.forever(on_forever)","pxt.json":"{\n    \"name\": \"GUARIDAN DEL CLIMA 5TO\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"MakerBit-LCD1602\": \"github:1010technologies/pxt-makerbit-lcd1602#v1.8.11\",\n        \"pxt-DHT11_DHT22\": \"github:alankrantas/pxt-dht11_dht22#v0.0.3\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n    